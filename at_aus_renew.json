[
  {
    "$import": "shared/common.json"
  },
  {
    "$import": "at-aus/renew_page_2.json"
  },
  {
    "id": "upload_residence_permit",
    "type": "action",
    "actions": [
      "Upload residence permit"
    ],
    "covered": true,
    "next": "maintenance_obligations"
  },
  {
    "id": "maintenance_obligations",
    "type": "decision",
    "question": "Are you obliged to make maintenance payments to other persons?",
    "covered": true,
    "branches": [
      {
        "label": "yes",
        "next": "handle_maintenance_obligations"
      },
      {
        "label": "no",
        "next": "statutory_violations"
      }
    ]
  },
  {
    "id": "handle_maintenance_obligations",
    "type": "action",
    "actions": [
      "Enter amount of maintenance payments",
      "Upload documents"
    ],
    "covered": true,
    "next": "statutory_violations"
  },
  {
    "id": "statutory_violations",
    "type": "action",
    "actions": [
      "Handle statutory violations"
    ],
    "covered": true,
    "next": "renew_page_2"
  },
  {
    "id": "apply_or_renew",
    "type": "decision",
    "question": "Would you like to apply for a new permit or renew an existing one?",
    "covered": true,
    "branches": [
      {
        "label": "Renew",
        "next": "intended_duration_of_stay"
      }
    ]
  },
  {
    "id": "intended_duration_of_stay",
    "type": "action",
    "actions": [
      "Enter intended duration of stay"
    ],
    "covered": true,
    "next": "periods_spent_abroad"
  },
  {
    "id": "periods_spent_abroad",
    "type": "decision",
    "question": "Have there been any interruptions ... of more than 6 months",
    "covered": true,
    "branches": [
      {
        "label": "yes",
        "next": "handle_periods_spent_abroad"
      },
      {
        "label": "no",
        "next": "existing_residence_permit"
      }
    ]
  },
  {
    "id": "handle_periods_spent_abroad",
    "type": "action",
    "actions": [
      "Fill data for periods spent abroad"
    ],
    "covered": true,
    "next": "existing_residence_permit"
  },
  {
    "id": "existing_residence_permit",
    "type": "decision",
    "question": "Do you already have a residence permit from a German Foreigners’ Registration Office?",
    "covered": true,
    "branches": [
      {
        "label": "yes",
        "next": "upload_residence_permit"
      },
      {
        "label": "no",
        "next": "can_not_continue"
      }
    ]
  }
]
